# 🔐 XClone Backend - Environment Variables Template
# ================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo a .env
# 2. Rellenar los valores según tu entorno
# 3. NUNCA commitear .env (está en .gitignore)
# 4. NUNCA compartir .env por chat/email
#
# Nota: Algunos valores son de ejemplo. Necesitarás tus propias claves.

# ==================== BASE DE DATOS ====================
# SQL Server Connection String
# Formato: Server=<host>,<port>;Database=<database>;User Id=<user>;Password=<password>;TrustServerCertificate=true;
# DESARROLLO (Local):
DefaultConnection=Server=localhost,1433;Database=XCloneDb;User Id=sa;Password=XClone@123;TrustServerCertificate=true;

# ALTERNATIVA si usas Windows Authentication:
# DefaultConnection=Server=localhost,1433;Database=XCloneDb;Integrated Security=true;TrustServerCertificate=true;

# ==================== JWT - AUTENTICACIÓN ====================

# Clave secreta para firmar tokens
# ⚠️ IMPORTANTE:
#   - Mínimo 32 caracteres
#   - Usa caracteres aleatorios
#   - DIFERENTE en producción
# Generar: https://www.uuidgenerator.net/ o usar una frase larga
JWT:Key=tu-clave-secreta-super-larga-minimo-32-caracteres-aleatorios-1234567890

# Identificador del emisor del token
JWT:Issuer=xclone-backend

# Identificador autorizado para usar el token
JWT:Audience=xclone-client

# Expiración del token en minutos (60 minutos = 1 hora)
# RECOMENDADO: 15-60 minutos para access token
JWT:ExpireMinutes=60

# ==================== MONGODB - LOGGING ====================
# URI de conexión a MongoDB
# DESARROLLO (Local):
MongoDb:ConnectionString=mongodb://localhost:27017

# PRODUCCIÓN (Atlas - Reemplazar valores):
# MongoDb:ConnectionString=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ==================== CLOUDINARY - ALMACENAMIENTO ====================
# Registrate en: https://cloudinary.com (Plan gratuito disponible)

# Cloud name del dashboard de Cloudinary
Cloudinary:CloudName=tu-cloud-name

# API Key desde el dashboard de Cloudinary
Cloudinary:ApiKey=tu-api-key

# API Secret - ⚠️ MANTÉN ESTO SECRETO
Cloudinary:ApiSecret=tu-api-secret

# ==================== LOGGING ====================
# Nivel de logging por defecto
# Opciones: Trace, Debug, Information, Warning, Error, Critical
Logging:LogLevel:Default=Information
Logging:LogLevel:Microsoft:AspNetCore=Warning

# ==================== AMBIENTE ====================
# ASPNETCORE_ENVIRONMENT=Development
# Opciones: Development, Staging, Production
# Los archivos appsettings.<Environment>.json serán cargados automáticamente

# ==================== CORS ====================
# Dominios permitidos para CORS (desarrollo)
# En producción, especificar solo dominios permitidos
AllowedCorsOrigins=http://localhost:3000,http://localhost:5173,https://app.example.com

# ==================== CARACTERÍSTICAS ====================
# Habilitar/deshabilitar características
Features:EnableSwagger=true
Features:EnableHealthChecks=true
Features:EnableRateLimiting=false

# =====================================================
# NOTAS DE SEGURIDAD:
# =====================================================
# 
# 1. NUNCA compartir este archivo por:
#    - Chat (Teams, Slack, etc)
#    - Email
#    - GitHub/GitLab
#    - Google Drive públicamente
#
# 2. NUNCA commitear .env
#    - Usar .env.example como template
#    - .env está en .gitignore
#
# 3. ROTAR secretos regularmente en PRODUCCIÓN
#
# 4. Usar variables de entorno del servidor
#    en lugar de archivos .env en producción
#
# =====================================================

# Eliminado: Líneas comentadas o valores dummy
